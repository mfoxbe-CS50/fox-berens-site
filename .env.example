# =============================================================================
# LeadForge AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# Supabase (Auth only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Airtable (Business data: leads, campaigns, contacts)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Make.com (Workflow automation — each scenario has its own webhook URL)
MAKE_WEBHOOK_CONTACT=
MAKE_WEBHOOK_NEWSLETTER=
MAKE_WEBHOOK_NEW_LEAD=

# Notion (Blog CMS)
NOTION_API_KEY=
NOTION_BLOG_DATABASE_ID=

# Analytics (PostHog or Plausible)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Make webhook URLs (accessible from client-side forms)
NEXT_PUBLIC_MAKE_WEBHOOK_CONTACT=
NEXT_PUBLIC_MAKE_WEBHOOK_NEWSLETTER=
